# ─────────────────────────────────────────────────────────────────────────────
# Ask Alpha — frontend environment
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of your Ask Alpha FastAPI backend (the ask-alpha-chat repo).
# Server-side only (never exposed to the browser — the frontend proxies through
# Next.js route handlers in app/api/*). No trailing slash. The /v1 prefix is
# added by the client, so point this at the API ROOT.
#   Local dev:  http://localhost:8000
#   Railway:    https://<your-service>.up.railway.app
ASK_ALPHA_API_URL=http://localhost:8000

# Supabase (project: "Projects DB" — the same project the backend writes to).
# These are safe to expose to the browser (publishable / anon key).
NEXT_PUBLIC_SUPABASE_URL=https://pqzsdxcjyqjjvfsunzak.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_1afhTCU-pMRQGG6l59Quow_szI2kBwt
